rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /ships/{shipId}/logbook/{entryId}
    // Document ID: entryId (string)
    // Fields:
    //   - id: string (required) - unique entry ID
    //   - timestamp: string (required) - ISO 8601 date-time
    //   - lat: number (required) - latitude
    //   - lng: number (required) - longitude
    //   - sog: number (optional) - speed over ground
    //   - cog: number (optional) - course over ground
    //   - weather: string (optional) - weather observations
    //   - fuel: string (optional) - fuel level
    //   - engineHours: string (optional) - engine hours
    //   - observations: string (optional) - general observations
    //   - signature: string (optional) - base64 signature
    //   - uid: string (required) - creator's UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidLogEntry(data) {
      return hasRequiredFields(['id', 'timestamp', 'lat', 'lng', 'uid']) &&
             hasOnlyAllowedFields(['id', 'timestamp', 'lat', 'lng', 'sog', 'cog', 'weather', 'fuel', 'engineHours', 'observations', 'signature', 'uid']) &&
             data.id is string && data.id.size() > 0 &&
             data.timestamp is string &&
             data.lat is number &&
             data.lng is number &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isValidIntelLogEntry(data) {
      return hasRequiredFields(['role', 'content', 'timestamp', 'uid']) &&
             hasOnlyAllowedFields(['role', 'content', 'timestamp', 'uid']) &&
             data.role is string &&  (data.role == 'ai' || data.role == 'user') &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
             data.timestamp is timestamp &&
             data.uid is string;
    }

    function isValidAlarmLogEntry(data) {
      return hasRequiredFields(['id', 'type', 'severity', 'message', 'timestamp', 'value', 'uid']) &&
             hasOnlyAllowedFields(['id', 'type', 'severity', 'message', 'timestamp', 'value', 'uid']) &&
             data.id is string &&
             data.type is string &&
             data.severity is string &&
             data.message is string &&
             data.timestamp is timestamp &&
             data.value is number &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "miguelonjaen@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /ships/{shipId}/logbook/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidLogEntry(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidLogEntry(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /artifacts/{appId}/public/data/intel_logs/{logId} {
      allow list, get: if isAuthenticated();
      allow create: if isAuthenticated() && isValidIntelLogEntry(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /artifacts/{appId}/public/data/alarm_logs/{alarmId} {
      allow list, get: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAlarmLogEntry(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
