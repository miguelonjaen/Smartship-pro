{
  "entities": {
    "LogEntry": {
      "title": "LogEntry",
      "description": "A single entry in the ship's logbook",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "sog": { "type": "number" },
        "cog": { "type": "number" },
        "weather": { "type": "string" },
        "fuel": { "type": "string" },
        "engineHours": { "type": "string" },
        "observations": { "type": "string" },
        "signature": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "timestamp", "lat", "lng", "uid"]
    },
    "IntelLogEntry": {
      "title": "IntelLogEntry",
      "description": "Intel chat message",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["role", "content", "timestamp", "uid"]
    },
    "AlarmLogEntry": {
      "title": "AlarmLogEntry",
      "description": "Historical record of a triggered alarm",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "severity": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "value": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["id", "type", "severity", "message", "timestamp", "uid"]
    }
  },
  "firestore": {
    "/ships/{shipId}/logbook/{entryId}": {
      "schema": "LogEntry",
      "description": "Collection of logbook entries for a specific ship"
    },
    "/ships/{shipId}/intel_logs/{logId}": {
      "schema": "IntelLogEntry",
      "description": "Intel chat messages for a ship"
    },
    "/ships/{shipId}/alarm_logs/{alarmId}": {
      "schema": "AlarmLogEntry",
      "description": "Historical log of alarms for a ship"
    }
  }
}
